FROM nginx:alpine

# Remove default nginx config and create directory if not exists
RUN rm -f /etc/nginx/conf.d/default.conf && mkdir -p /etc/nginx/templates

# Generate default nginx config in container
RUN echo '{"upstream_name":"auth_service"}' > /tmp/upstream_map.txt && \
    (
      {
        cat /tmp/upstream_map.txt | while IFS=':' read -r upstream_name _; do
          echo "upstream $upstream_name {"
          echo "  server $upstream_name:8080;"
          echo "}"
          echo ""
        done
        
        echo "server {"
        echo "  listen 80;"
        echo "  client_max_body_size 10m;"
        echo "  time_align off;"
        echo "  worker_connections 1024;"
        echo "  worker_limit;"
        echo "  worker_processes auto;"
        echo ""
        echo "  map \\$upstream_host \\$http_x_forwarded_host_custom {"
        echo "      default '';"
        echo "      \\\"auth-service\\\" \\\"auth-service\\\";"
        echo "      \\\"user-service\\\" \\\"user-service\\\";"
        echo "      \\\"quiz-service\\\" \\\"quiz-service\\\";"
        echo "      \\\"result-service\\\" \\\"result-service\\\";"
        echo "      \\\"notification-service\\\" \\\"notification-service\\\";"
        echo "  };"
        echo ""
        
        echo "  upstream auth_service {"
        echo "    server auth-service:8080;"
        echo "    proxy_connect_timeout 5s;"
        echo "    proxy_read_timeout 60s;"
        echo "  };"
        echo ""
        echo "  upstream user_service {"
        echo "    server user-service:8080;"
        echo "    proxy_connect_timeout 5s;"
        echo "    proxy_read_timeout 60s;"
        echo "  };"
        echo ""
        echo "  upstream quiz_service {"
        echo "    server quiz-service:8080;"
        echo "    proxy_connect_timeout 5s;"
        echo "    proxy_read_timeout 60s;"
        echo "  };"
        echo ""
        echo "  upstream result_service {"
        echo "    server result-service:8080;"
        echo "    proxy_connect_timeout 5s;"
        echo "    proxy_read_timeout 60s;"
        echo "  };"
        echo ""
        echo "  upstream notification_service {"
        echo "    server notification-service:8080;"
        echo "    proxy_connect_timeout 5s;"
        echo "    proxy_read_timeout 300s;"
        echo "  };"
        echo ""
        echo "  server {"
        echo "    listen 80 default_server;"
        echo "    listen [::]:80 default_server;"
        echo ""
        echo "    location = / {"
        echo "       default_type application/json;"
        echo "       return 200 '{\\\"status\\\":\\\"ok\\\", \\\"message\\\":\\\"Quiz Backend API Gateway is running!\\\",}';"
        echo "    }"
        echo ""
        echo "    location /register {"
        echo "       proxy_pass http://auth_service;"
        echo "       proxy_set_header Host \\$host;"
        echo "       proxy_set_header X-Real-IP \\$remote_addr;"
        echo "       proxy_set_header X-Forwarded-For \\$proxy_add_x_forwarded_for;"
        echo "       proxy_set_header X-Forwarded-Proto \\$scheme;"
        echo "    }"
        echo ""
        echo "    location /login {"
        echo "       proxy_pass http://auth_service;"
        echo "       proxy_set_header Host \\$host;"
        echo "       proxy_set_header X-Real-IP \\$remote_addr;"
        echo "       proxy_set_header X-Forwarded-For \\$proxy_add_x_forwarded_for;"
        echo "       proxy_set_header X-Forwarded-Proto \\$scheme;"
        echo "    }"
        echo ""
        echo "    # User Service endpoints"
        echo "    location /users {"
        echo "       proxy_pass http://user_service;"
        echo "       proxy_set_header Host \\$host;"
        echo "       proxy_set_header X-Real-IP \\$remote_addr;"
        echo "       proxy_set_header X-Forwarded-For \\$proxy_add_x_forwarded_for;"
        echo "       proxy_set_header X-Forwarded-Proto \\$scheme;"
        echo "    }"
        echo ""
        echo "    # Quiz Service endpoints"
        echo "    location /quizzes {"
        echo "       proxy_pass http://quiz_service;"
        echo "       proxy_set_header Host \\$host;"
        echo "       proxy_set_header X-Real-IP \\$remote_addr;"
        echo "       proxy_set_header X-Forwarded-For \\$proxy_add_x_forwarded_for;"
        echo "       proxy_set_header X-Forwarded-Proto \\$scheme;"
        echo "    }"
        echo ""
        echo "    # Result Service endpoints"
        echo "    location /results {"
        echo "       proxy_pass http://result_service;"
        echo "       proxy_set_header Host \\$host;"
        echo "       proxy_set_header X-Real-IP \\$remote_addr;"
        echo "       proxy_set_header X-Forwarded-For \\$proxy_add_x_forwarded_for;"
        echo "       proxy_set_header X-Forwarded-Proto \\$scheme;"
        echo "    }"
        echo ""
        echo "    # Notification Service endpoints"
        echo "    location /notifications {"
        echo "       proxy_pass http://notification_service;"
        echo "       proxy_set_header Host \\$host;"
        echo "       proxy_set_header X-Real-IP \\$remote_addr;"
        echo "       proxy_set_header X-Forwarded-For \\$proxy_add_x_forwarded_for;"
        echo "       proxy_set_header X-Forwarded-Proto \\$scheme;"
        echo "    }"
        echo "  "
        echo "}"
        echo "}"
      }
    ) > /etc/nginx/nginx.conf

RUN touch "/etc/nginx/default.conf.template"
