# Hardcoded environment variables for GCP VM Docker deployment
# Update these values based on your specific needs

# Database PostgreSQL Connection
# Change to your actual database configuration
DB_HOST=db                              # Use 'db' for docker-compose network or actual DB hostname on GCP VM
DB_USER=quiz_user                       
DB_PASSWORD=quiz_password               
DB_NAME=quiz_db                         
DB_PORT=5432                            # Standard PostgreSQL port

# JWT Authentication
# CHANGE THIS to a strong, cryptographically secure random string
# Generate with: openssl rand -base64 32
JWT_SECRET=supersecretkey               # Replace this with a secure random secret key

# API Gateway
# Change port 8080 to match your main application port if needed
PORT=8080                              # The port where the main application listens
